{
  "version": 3,
  "name": "SGAI Gateway",
  "port": 8080,
  "timeout": "3000ms",
  "endpoints": [
    {
      "endpoint": "/api/v1/activos",
      "method": "GET",
      "output_encoding": "no-op",
      "backend": [{"url_pattern": "/api/v1/activos", "host": ["http://backend:8000"], "encoding": "no-op"}]
    },
    {
      "endpoint": "/api/v1/activos/{id}",
      "method": "GET",
      "output_encoding": "no-op",
      "backend": [{"url_pattern": "/api/v1/activos/{id}", "host": ["http://backend:8000"], "encoding": "no-op"}]
    },
    {
      "endpoint": "/api/v1/activos",
      "method": "POST",
      "output_encoding": "no-op",
      "backend": [{"url_pattern": "/api/v1/activos", "host": ["http://backend:8000"], "encoding": "no-op"}]
    }
  ]
}
